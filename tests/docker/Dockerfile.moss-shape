# The shape moss actually runs, in a container.
#
# moss spawns nexusd as a CHILD PROCESS inside its own server container, bound
# to the container's loopback, and talks to it in-process. Everything about the
# security story rests on that: the daemon faces no network, and the only thing
# that can reach it is the process that started it.
#
# This image reproduces exactly that — daemon and client in one container, one
# trust domain — so the tests below exercise the real topology rather than a
# host-side approximation.
#
# Build from the repo root:
#   docker build -f tests/docker/Dockerfile.moss-shape -t nexus-moss-shape .
FROM rust:1-slim-bookworm AS build

RUN apt-get update && apt-get install -y --no-install-recommends \
        protobuf-compiler pkg-config libssl-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src
COPY . .
RUN cargo build --release -p nexus-cluster --bin nexusd-cluster

FROM python:3.12-slim-bookworm

# The client half. moss's is TypeScript over the same protos; ours is Python
# compiled from this repo's own vfs.proto at run time, so the wire under test
# is the wire that ships.
RUN pip install --no-cache-dir grpcio grpcio-tools

COPY --from=build /src/target/release/nexusd-cluster /usr/local/bin/nexusd-cluster
COPY proto /work/proto
COPY tests/docker/moss_shape_probe.py /work/moss_shape_probe.py

WORKDIR /work
ENTRYPOINT ["python", "moss_shape_probe.py"]
